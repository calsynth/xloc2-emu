+
+static inline int32_t signed_multiply_accumulate_32x16t(int32_t sum, int32_t a, uint32_t b)
+{
+	return sum + signed_multiply_32x16t(a, b);
+}
+
+static inline uint32_t logical_and(uint32_t a, uint32_t b)
